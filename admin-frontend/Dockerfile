# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Accept build arguments
ARG VITE_API_URL
ARG VITE_BASE_PATH
ARG VITE_PAY_CARDHOLDER
ARG VITE_PAY_CARD_NUMBER
ARG VITE_PAY_CARD_EXPIRY
ARG VITE_PAY_CARD_CVV
ARG VITE_PAY_ADDRESS1
ARG VITE_PAY_ADDRESS2
ARG VITE_PAY_CITY
ARG VITE_PAY_COUNTRY
ARG VITE_PAY_PROVINCE
ARG VITE_PAY_POSTAL

# Set environment variables for Vite build
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_BASE_PATH=$VITE_BASE_PATH
ENV VITE_PAY_CARDHOLDER=$VITE_PAY_CARDHOLDER
ENV VITE_PAY_CARD_NUMBER=$VITE_PAY_CARD_NUMBER
ENV VITE_PAY_CARD_EXPIRY=$VITE_PAY_CARD_EXPIRY
ENV VITE_PAY_CARD_CVV=$VITE_PAY_CARD_CVV
ENV VITE_PAY_ADDRESS1=$VITE_PAY_ADDRESS1
ENV VITE_PAY_ADDRESS2=$VITE_PAY_ADDRESS2
ENV VITE_PAY_CITY=$VITE_PAY_CITY
ENV VITE_PAY_COUNTRY=$VITE_PAY_COUNTRY
ENV VITE_PAY_PROVINCE=$VITE_PAY_PROVINCE
ENV VITE_PAY_POSTAL=$VITE_PAY_POSTAL

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm install

# Copy source code
COPY . .

# Build the app
RUN npm run build

# Production stage
FROM nginx:alpine

# Copy built assets from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx configuration
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Expose port 80
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
